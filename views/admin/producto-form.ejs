<%- include("../partials/header", { titulo: mode === 'alta' ? 'Nuevo Producto' : 'Editar Producto' }) %>
    <div id="productoFormContainer" data-mode="<%= mode %>">
        <div class="form-card">
            <h2><%= mode === 'alta' ? 'Nuevo Producto' : 'Editar Producto' %></h2>

            <% if (mode === 'editar') { %>
                <div class="cargar-section">
                    <input type="number" id="cargarId" placeholder="Ingresar ID del producto">
                    <button id="cargarBtn" class="btn-cargar">Cargar</button>
                </div>
                <hr>
            <% } %>

            <form action="/admin/productos/<%= mode === 'alta' ? 'nuevo' : '0/editar' %>" method="POST" enctype="multipart/form-data" id="productoForm">
                <input type="hidden" name="productoId" id="productoId">

                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" name="nombre" id="nombre" required>
                </div>

                <div class="form-group">
                    <label>Categoría</label>
                    <input type="text" name="categoria" id="categoria" required>
                </div>

                <div class="form-group">
                    <label>Precio</label>
                    <input type="number" step="0.01" name="precio" id="precio" required>
                </div>

                <div class="form-group">
                    <label>Imagen</label>
                    <input type="file" name="imagen" id="imagen" accept="image/*">
                    <div id="preview" class="preview-container">
                        <img id="previewImg">
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="btn btn-primary">
                    <%= mode === 'alta' ? 'Crear producto' : 'Guardar cambios' %>
                </button>
            </form>
        </div>
    </div>
<%- include("../partials/footer") %>
