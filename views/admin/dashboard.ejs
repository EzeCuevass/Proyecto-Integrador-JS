<%- include("../partials/header", { titulo: "Dashboard" }) %>
    <h2 class="page-title">Panel de Administración</h2>
    <a href="/admin/productos/nuevo" class="btn-new">+ Nuevo Producto</a>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Imagen</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Precio</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <% productos.forEach(p => { %>
                <tr>
                    <td><%= p.id %></td>
                    <td>
                        <% if (p.imagen) { %>
                            <img src="/uploads/<%= p.imagen %>" alt="<%= p.nombre %>">
                        <% } else { %>
                            <span class="no-image">Sin imagen</span>
                        <% } %>
                    </td>
                    <td><%= p.nombre %></td>
                    <td><%= p.categoria %></td>
                    <td>$<%= parseFloat(p.precio).toFixed(2) %></td>
                    <td>
                        <% if (p.activo) { %>
                            <span class="status-active">Activo</span>
                        <% } else { %>
                            <span class="status-inactive">Inactivo</span>
                        <% } %>
                    </td>
                    <td class="action-cell">
                        <a href="/admin/productos/<%= p.id %>/editar" class="btn-warning">Editar</a>
                        <% if (p.activo) { %>
                            <form action="/admin/productos/<%= p.id %>/eliminar" method="POST" onsubmit="return confirm('¿Estás seguro de desactivar este producto?')">
                                <button type="submit" class="btn-delete">Desactivar</button>
                            </form>
                        <% } else { %>
                            <form action="/admin/productos/<%= p.id %>/activar" method="POST" onsubmit="return confirm('¿Estás seguro de activar este producto?')">
                                <button type="submit" class="btn-success">Activar</button>
                            </form>
                        <% } %>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
<%- include("../partials/footer") %>
